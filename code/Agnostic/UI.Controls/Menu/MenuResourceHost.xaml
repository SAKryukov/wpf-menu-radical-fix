<agnostic:ResourceHost x:Class="SA.Agnostic.UI.Controls.MenuResourceHost"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:system="clr-namespace:System;assembly=netstandard"
    xmlns:controls="clr-namespace:SA.Agnostic.UI.Controls"    
    xmlns:agnostic="clr-namespace:SA.Agnostic.UI.Markup;assembly=Agnostic.UI">

    <agnostic:ResourceHost.Resources>

        <controls:DefaultSet x:Key="{x:Type controls:DefaultSet}"
            LineBrush="Gray"
            BorderThickness="2"
            CornerRadius="4.3"
            SeparatorThickness="1"
            SeparatorMargin="0 4 0 4">
            <controls:DefaultSet.IconAlignment>
                <controls:IconAlignment
                    Horizontal="Center"
                    Vertical="Center"/>
            </controls:DefaultSet.IconAlignment>
            <controls:DefaultSet.Background>
                <controls:Background
                    Normal="White"
                    Highlight="LightBlue"/>
            </controls:DefaultSet.Background>
            <controls:DefaultSet.Foreground>
                <controls:Foreground>
                    <controls:Foreground.Icon>
                        <controls:ElementForeground
                            Normal="Black"
                            Highlight="Black"
                            Disabled="#AAAAAA"/>
                    </controls:Foreground.Icon>
                    <controls:Foreground.Header>
                        <controls:ElementForeground
                            Normal="Black"
                            Highlight="Black"
                            Disabled="#AAAAAA"/>
                    </controls:Foreground.Header>
                    <controls:Foreground.Gesture>
                        <controls:ElementForeground
                            Normal="Black"
                            Highlight="Black"
                            Disabled="#AAAAAA"/>
                    </controls:Foreground.Gesture>
                </controls:Foreground>
            </controls:DefaultSet.Foreground>
            <controls:DefaultSet.Margin>
                <controls:Margin
                    Icon="12 0 0 0"
                    Header="14 0 16 0"
                    Gesture="0 0 16 0"/>
            </controls:DefaultSet.Margin>
        </controls:DefaultSet>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="{Binding Nicety.ForegroundHeaderNormal, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"/>
            <!-- Setters for OverridesDefaultStyle, Background, Padding, etc. -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="templateRoot"
                            Background="{Binding Nicety.BackgroundNormal, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"
                            CornerRadius="{Binding Nicety.CornerRadius, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="MenuIconGroup"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="MenuHeaderGroup"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Popup x:Name="PART_Popup"
                                    IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                    Placement="Bottom"
                                    AllowsTransparency="True"
                                    Focusable="False">
                                    <!-- Drops down using inherited parent MenuBase background brushes -->
                                    <Border x:Name="SubmenuBorder" 
                                        Background="{Binding Nicety.BackgroundNormal, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"
                                        BorderBrush="{Binding Nicety.LineBrush, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"
                                        BorderThickness="{Binding Nicety.BorderThickness, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"
                                        CornerRadius="{Binding Nicety.CornerRadius, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}">
                                        <Grid Grid.IsSharedSizeScope="True">
                                            <ItemsPresenter x:Name="ItemsPresenter"/>
                                        </Grid>
                                    </Border>
                                </Popup>                        
                                <ContentControl
                                    Grid.Column="0"
                                    x:Name="iconContainer"
                                    Content="{TemplateBinding Icon}"
                                    HorizontalAlignment="{Binding Nicety.IconAlignmentHorizontal, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"
                                    VerticalAlignment="{Binding Nicety.IconAlignmentVertical, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"
                                    Foreground="{Binding Nicety.ForegroundIconNormal, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"
                                    Margin="{Binding Nicety.MarginIcon, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"/>
                                <ContentPresenter
                                    Grid.Column="1"
                                    ContentSource="Header"
                                    Margin="{Binding Nicety.MarginHeader, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}" RecognizesAccessKey="True" />
                                <TextBlock
                                    Grid.Column="2"
                                    x:Name="gestureText"
                                    FontWeight="Normal"
                                    Text="{TemplateBinding InputGestureText}"
                                    Foreground="{Binding Nicety.ForegroundGestureNormal, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"
                                    Margin="{Binding Nicety.MarginGesture, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="templateRoot" Property="Background"
                                    Value="{Binding Nicety.BackgroundHighlight, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"/>
                                <Setter Property="Foreground" Value="{Binding Nicety.ForegroundHeaderHighlight, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"/>
                                <Setter Property="Foreground" TargetName="iconContainer" Value="{Binding Nicety.ForegroundIconHighlight, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"/>
                                <Setter Property="Foreground" TargetName="gestureText" Value="{Binding Nicety.ForegroundGestureHighlight, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"/>
                            </Trigger>                            
                            <Trigger Property="IsEnabled" Value="True"> <!-- Antidote for the programmatic Bold focus anomaly -->
                                <Setter Property="FontWeight" Value="Normal" />
                            </Trigger>                     
                            <Trigger Property="IsEnabled" Value="False"> <!-- Antidote for the programmatic Bold focus anomaly -->
                                <Setter Property="FontWeight" Value="Normal" />
                                <Setter Property="Foreground" Value="{Binding Nicety.ForegroundHeaderDisabled, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}" />
                                <Setter Property="Foreground" TargetName="iconContainer" Value="{Binding Nicety.ForegroundIconDisabled, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"/>
                                <Setter Property="Foreground" TargetName="gestureText" Value="{Binding Nicety.ForegroundGestureDisabled, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"/>
                            </Trigger>                     
                            <Trigger Property="Icon" Value="{x:Null}">
                                <Setter TargetName="iconContainer" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="Icon" Value="">
                                <Setter TargetName="iconContainer" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="InputGestureText" Value="">
                                <Setter TargetName="gestureText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="InputGestureText" Value="{x:Null}">
                                <Setter TargetName="gestureText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style> <!-- MenuItem -->

        <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="{x:Type Separator}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Margin" Value="{Binding Nicety.SeparatorMargin, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"/>
            <Setter Property="Template">
                <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="MenuIconGroup"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="1"
                            Height="{Binding Nicety.SeparatorThickness, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"
                            Fill="{Binding Nicety.LineBrush, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"/>
                    </Grid>
                </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style> <!-- Separator -->

        <Style TargetType="{x:Type MenuBase}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="BorderBrush" Value="{Binding Nicety.LineBrush, RelativeSource={RelativeSource Self}}" />
            <Setter Property="BorderThickness" Value="{Binding Nicety.BorderThickness, RelativeSource={RelativeSource Self}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuBase}">
                        <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=MenuBase}}"
                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=MenuBase}}"
                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=MenuBase}}"
                                CornerRadius="{Binding Nicety.CornerRadius, RelativeSource={RelativeSource AncestorType={x:Type MenuBase}}}"
                                Padding="0">
                            <Grid Grid.IsSharedSizeScope="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style> <!-- MenuBase -->

        <Style TargetType="{x:Type controls:ContextMenu}" BasedOn="{StaticResource {x:Type MenuBase}}">
            <Setter Property="Tag" Value="True"/>
        </Style> <!-- ContextMenu -->
        <Style TargetType="{x:Type controls:Menu}" BasedOn="{StaticResource {x:Type MenuBase}}">
            <Setter Property="Tag" Value="False"/>
        </Style> <!-- Menu -->

    </agnostic:ResourceHost.Resources>

</agnostic:ResourceHost>
